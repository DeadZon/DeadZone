# DeadZone Fly builder context allowlist
# Default: send nothing, then allow only runtime source.
*

!.dockerignore
!.gitattributes
!requirements.txt
!docker/
!docker/**
!fly.toml
!server/
!server/**
!factory/
!factory/**
!registry/
!registry/**
!queues/
!queues/**
!scripts/
!scripts/**
!assets/
!assets/**
!third_party/
!third_party/mezo_core/
!third_party/mezo_core/**

third_party/mezo_core/MEZO_APP
third_party/mezo_core/MEZO_APP/**
third_party/mezo_core/_asset_downloads
third_party/mezo_core/_asset_downloads/**
third_party/mezo_core/output
third_party/mezo_core/output/**
third_party/mezo_core/work
third_party/mezo_core/work/**
third_party/mezo_core/tmp
third_party/mezo_core/tmp/**
third_party/mezo_core/logs
third_party/mezo_core/logs/**
third_party/mezo_core/downloads
third_party/mezo_core/downloads/**
third_party/mezo_core/payload_extracted
third_party/mezo_core/payload_extracted/**

# Windows-only tools — not needed on Linux builder
third_party/mezo_core/bin/Windows
third_party/mezo_core/bin/Windows/**
third_party/mezo_core/bin/openssl
third_party/mezo_core/bin/openssl/**
third_party/mezo_core/bin/extra_flash
third_party/mezo_core/bin/extra_flash/**
# Flash package — for device flashing, not building
third_party/mezo_core/flash
third_party/mezo_core/flash/**
# Template Windows executables
third_party/mezo_core/templates
third_party/mezo_core/templates/**
# MEZO_LEGEND pre-built compare data — not needed at builder runtime
third_party/mezo_core/MEZO_LEGEND
third_party/mezo_core/MEZO_LEGEND/**
# Windows executables and DLLs anywhere in context
**/*.exe
**/*.dll

output
output/**
