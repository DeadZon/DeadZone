# Kaorios Toolbox
persist.sys.kaorios=kousei
ro.control_privapp_permissions=

# Boot state / AVB
ro.boot.vbmeta.device_state=locked
ro.boot.verifiedbootstate=green
ro.boot.veritymode=enforcing
ro.boot.vbmeta.invalidate_on_error=yes
ro.boot.vbmeta.size=4096
ro.boot.vbmeta.hash_alg=sha256
ro.boot.vbmeta.avb_version=1.3

# Bootloader / lock state
ro.boot.flash.locked=1
ro.secureboot.lockstate=locked
sys.oem_unlock_allowed=0
ro.boot.realme.lockstate=1

# Vendor boot state
vendor.boot.vbmeta.device_state=locked
vendor.boot.verifiedbootstate=green

#Disable useless logging and debugging stuff
debugtool.anrhistory=0
profiler.hung.dumpdobugreport=false
profiler.launch=false
persist.sys.offlinelog.kernel=false
persist.sys.offlinelog.logcat=false
persist.sys.offlinelog.logcatkernel=false
persist.sys.perf.debug=false
persist.sys.whetstone.level=0
persist.wpa_supplicant.debug=false
ro.logdumpd.enabled=0
ro.logd.size.stats=4K
ro.lmk.debug=false
sys.miui.ndcd=off
vendor.bluetooth.startbtlogger=false

#audiosafebypass
audio.safemedia.bypass=true
vendor.audio.safemedia.bypass=true

#mediahaptics
ro.odm.mm.vibrator.audio_haptic_support=true
sys.haptic.media=true
sys.haptic.lowPowerMode=true
sys.haptic.onetrack=true

#GPU turner
debug.performance.tuning=1
persist.sys.use_dithering=1
video.accelerate.hw=1
hw3d.force=1
debug.egl.hw=1
debug.sf.hw=1

#battery optimization
ro.ril.disable.power.collapse=1
pm.sleep_mode=1
wifi.supplicant_scan_interval=180
ro.mot.eri.losalert.delay=1000
power.saving.mode=1

#network and Wi-Fi
net.tcp.buffersize.default=4096,87380,256960,4096,16384,256960
net.tcp.buffersize.wifi=524288,1048576,2097152,262144,524288,1048576
ro.ril.hsxpa=3
ro.ril.gprsclass=10
persist.telephony.support.ipv6=1
persist.telephony.support.ipv4=1

#ram
dalvik.vm.heapsize=256m
ro.sys.fw.bg_apps_limit=10
ro.config.low_ram=false
persist.sys.purgeable_assets=1
sysctl.vm.swappiness=10

#launcher
persist.sys.ui.hw=1
debug.hwui.render_dirty_regions=false
persist.sys.scrollingcache=3
ro.config.hw_fast_dormancy=1

#AOD
ro.vendor.mi_sf.aod_mode_ddic_refresh_rate=1